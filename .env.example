# swiss-democracy-mcp — environment configuration
# Copy to .env (git-ignored) and fill in. Swissvotes & BFS need NO credentials.

# --- SRGSSR Polis (optional; only the democracy_polis_* tools need these) ---
# Free registration: https://developer.srgssr.ch
SRGSSR_CONSUMER_KEY=replace-with-your-key
SRGSSR_CONSUMER_SECRET=replace-with-your-secret

# --- Transport (defaults shown) ---
MCP_TRANSPORT=stdio          # stdio | streamable_http
MCP_HOST=127.0.0.1           # set 0.0.0.0 ONLY inside a container/cloud deploy
MCP_PORT=8000
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
